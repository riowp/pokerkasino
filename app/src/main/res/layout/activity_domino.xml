<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_table"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/game_domino"
                android:textColor="@color/gold"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83E\uDE99 "
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/gold"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Lawan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_felt"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/txtBotA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bot A: 7 kartu"
                android:textColor="@color/cream"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtBotB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Bot B: 7 kartu"
                android:textColor="@color/cream"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtBotC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Bot C: 7 kartu"
                android:textColor="@color/cream"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Papan -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Papan"
            android:textColor="@color/gold"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/boardWrap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_felt"
            android:minHeight="60dp"
            android:orientation="vertical"
            android:padding="8dp" />

        <TextView
            android:id="@+id/txtEnds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Ujung kiri: -     Ujung kanan: -"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:minHeight="44dp"
            android:text="Tekan Bagikan untuk mulai"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Kartu pemain -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Kartu Anda"
            android:textColor="@color/gold"
            android:textSize="13sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:id="@+id/handScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/handRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="94dp"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <!-- Panel taruhan -->
        <LinearLayout
            android:id="@+id/betPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ante (% dari total chip)"
                android:textColor="@color/cream"
                android:textSize="14sp" />

            <com.rio.casinoklasik.ui.BetSliderView
                android:id="@+id/sliderBet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnDeal"
            style="@style/GoldBtn"
            android:layout_width="match_parent"
            android:layout_marginTop="8dp"
            android:text="Bagikan Kartu" />

        <Button
            android:id="@+id/btnPass"
            style="@style/DarkBtn"
            android:layout_width="match_parent"
            android:layout_marginTop="8dp"
            android:text="Lewati (Pass)"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
