<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_table"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/game_slot"
                android:textColor="@color/gold"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83E\uDE99 "
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/gold"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Reel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_felt"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="20dp">

            <com.rio.casinoklasik.ui.ReelView
                android:id="@+id/reel1"
                android:layout_width="80dp"
                android:layout_height="100dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/bg_reel" />

            <com.rio.casinoklasik.ui.ReelView
                android:id="@+id/reel2"
                android:layout_width="80dp"
                android:layout_height="100dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/bg_reel" />

            <com.rio.casinoklasik.ui.ReelView
                android:id="@+id/reel3"
                android:layout_width="80dp"
                android:layout_height="100dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/bg_reel" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Tarik untuk memutar!"
            android:textColor="@color/gold"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Taruhan -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Taruhan / putaran (% dari total chip)"
            android:textColor="@color/cream"
            android:textSize="12sp" />

        <com.rio.casinoklasik.ui.BetSliderView
            android:id="@+id/sliderBet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/btnSpin"
            style="@style/GoldBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="PUTAR"
            android:textSize="18sp" />

        <!-- Auto spin -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Auto spin (putar otomatis)"
            android:textColor="@color/cream"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAuto10"
                style="@style/DarkBtn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="x10" />

            <Button
                android:id="@+id/btnAuto25"
                style="@style/DarkBtn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="x25" />

            <Button
                android:id="@+id/btnAuto50"
                style="@style/DarkBtn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="x50" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStopAuto"
            style="@style/DarkBtn"
            android:layout_width="match_parent"
            android:layout_marginTop="4dp"
            android:text="STOP AUTO"
            android:visibility="gone" />

        <!-- Tabel bayaran -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_balance"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tabel Bayaran (x taruhan)"
                android:textColor="@color/gold"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPaytable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/cream"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
