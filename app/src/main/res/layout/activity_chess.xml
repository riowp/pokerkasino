<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_table"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/game_chess"
                android:textColor="@color/gold"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83E\uDE99 "
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/gold"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Setup -->
        <LinearLayout
            android:id="@+id/setupPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_felt"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Level Bot"
                android:textColor="@color/gold"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnEasy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_diff_normal"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:text="Easy"
                    android:textColor="@color/cream"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_diff_normal"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:text="Medium"
                    android:textColor="@color/cream"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnHard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_diff_normal"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:text="Hard"
                    android:textColor="@color/cream"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Taruhan (% dari total chip)"
                android:textColor="@color/gold"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.rio.casinoklasik.ui.BetSliderView
                android:id="@+id/sliderBet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/txtPayInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text=""
                android:textColor="@color/cream"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnPlay"
                style="@style/GoldBtn"
                android:layout_width="match_parent"
                android:layout_marginTop="10dp"
                android:text="Main" />
        </LinearLayout>

        <!-- Game -->
        <LinearLayout
            android:id="@+id/gamePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.rio.casinoklasik.ui.ChessBoardView
                android:id="@+id/boardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text=""
                android:textColor="@color/gold"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:minHeight="26dp"
                android:text=""
                android:textColor="@color/cream"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnHint"
                    style="@style/GoldBtn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Saran Gerakan" />

                <Button
                    android:id="@+id/btnResign"
                    style="@style/DarkBtn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Menyerah" />
            </LinearLayout>

            <Button
                android:id="@+id/btnNewGame"
                style="@style/GoldBtn"
                android:layout_width="match_parent"
                android:layout_marginTop="6dp"
                android:text="Main Lagi"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
