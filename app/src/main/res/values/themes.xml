<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CasinoKlasik" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryDark">@color/table_bg</item>
        <item name="colorAccent">@color/gold</item>
        <item name="android:statusBarColor">@color/table_bg</item>
        <item name="android:windowBackground">@color/table_bg</item>
        <item name="android:windowAnimationStyle">@style/WindowAnim</item>
    </style>

    <style name="WindowAnim" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>
</resources>
